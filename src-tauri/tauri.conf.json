{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "the-manager",
  "version": "0.1.0",
  "identifier": "com.vvasconceloss.themanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "The Manager",
        "width": 800,
        "height": 600,
        "focus": true,
        "devtools": true,
        "closable": false,
        "fullscreen": false,
        "hiddenTitle": false,
        "minimizable": false,
        "maximizable": false,
        "dragDropEnabled": false,
        "allowLinkPreview": false,
        "zoomHotkeysEnabled": false,
        "browserExtensionsEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'",
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
